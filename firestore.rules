// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: /users/{userId}/settings
// Document ID: current
// Fields:
//   - userId: string (required) - The Firebase Auth UID
//   - canvasUrl: string (required) - The base URL of the Canvas instance
//   - apiToken: string (required) - The personal access token
//   - notificationThresholds: list (optional) - Hours before deadline to notify
//
// Collection: /users/{userId}/assignments
// Document ID: {assignmentId}
// Fields:
//   - assignmentId: string (required) - Canvas assignment ID
//   - courseId: string (required) - Canvas course ID
//   - courseName: string (required) - Course name
//   - name: string (required) - Assignment name
//   - dueAt: timestamp (required) - Deadline
//   - userId: string (required) - Owner UID
//   - notifiedThresholds: list (optional) - Thresholds already notified
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // Domain Validators
    function isValidUserSettings(data) {
      return data.keys().hasAll(['userId', 'canvasUrl', 'apiToken']) &&
             data.userId == request.auth.uid &&
             isValidUrl(data.canvasUrl) &&
             data.apiToken is string && data.apiToken.size() > 0 &&
             (!('notificationThresholds' in data) || data.notificationThresholds is list);
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['assignmentId', 'userId', 'dueAt']) &&
             data.userId == request.auth.uid &&
             data.assignmentId is string &&
             data.dueAt is timestamp &&
             (!('notifiedThresholds' in data) || data.notifiedThresholds is list);
    }

    // Match Rules
    match /users/{userId} {
      match /settings/current {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidUserSettings(request.resource.data);
      }

      match /assignments/{assignmentId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidAssignment(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
